# ============================================================================
# ARROW PROJECT - GITIGNORE RULES
# Protects sensitive credentials and temporary files from being committed
# ============================================================================

# CRITICAL: Protect all sensitive credential files
# Never commit actual .env files to the repository
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test

# Python virtual environments and caches
venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE and editor configuration
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Arrow Project specific
arrow_data/generated/logs/
storage/vision_snapshots/*.png
storage/vision_snapshots/*.jpg

# OS temporary files
.DS_Store
Thumbs.db
*.tmp

# Logs
*.log
logs/

# Local testing files
test_output/
*.local
