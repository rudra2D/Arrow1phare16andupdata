# ============================================================================
# ARROW PROJECT - SECURE CONFIGURATION TEMPLATE
# ============================================================================
# CRITICAL SECURITY NOTICE:
# This file is a TEMPLATE. Do NOT commit the actual .env file to the repository.
# Always create a local .env file with your actual credentials.
# The .env file is listed in .gitignore and will never be tracked.
#
# Copy this file to .env and fill in your actual API keys:
#   cp .env.example .env
# ============================================================================

# ============================================================================
# CORE LLM CONFIGURATION
# ============================================================================
# Gemini API Key for core LLM and data orchestration routing
# Get your free key from: https://aistudio.google.com
# Production keys available via Google Cloud Console
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Selection (optional, defaults to gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-pro

# ============================================================================
# TELEGRAM BOT INTEGRATION
# ============================================================================
# Telegram Bot Token for system integration and communication channels
# Create a bot via @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Telegram User ID for remote control authorization
# Get your ID from @userinfobot on Telegram
TELEGRAM_USER_ID=your_telegram_user_id_here

# Telegram Admin Chat ID (typically same as TELEGRAM_USER_ID)
# Strict authorization - only this chat can execute privileged commands
ADMIN_CHAT_ID=your_admin_chat_id_here

# ============================================================================
# VOICE CONFIGURATION
# ============================================================================
# Duration (in seconds) for voice recording
VOICE_RECORD_SECONDS=7

# Voice Language and Locale
VOICE_LANGUAGE=en-US

# ============================================================================
# PRIVATE STORAGE & FILE ROUTING (Phase 7)
# ============================================================================
# Private server endpoint for secure file uploads
PRIVATE_SERVER_UPLOAD_URL=https://your-private-server.com/upload

# Backup storage endpoint for redundancy
PRIVATE_BACKUP_UPLOAD_URL=https://your-backup-server.com/upload

# Authentication token for private storage access
PRIVATE_STORAGE_AUTH_TOKEN=your_private_storage_auth_token_here

# ============================================================================
# CAMERA & HARDWARE CONFIGURATION
# ============================================================================
# Wi-Fi Camera RTSP Feed URL for live snapshot capture
CAMERA_RTSP_URL=rtsp://your_camera_ip:554/stream

# ============================================================================
# [FUTURE_API_EXTENSIONS] - RESERVED SLOTS FOR NEW INTEGRATIONS
# ============================================================================
# OpenAI API Key (when integrated)
# OPENAI_API_KEY=your_openai_api_key_here

# Database Connection String
# DATABASE_URL=your_database_url_here

# Cloud Storage Credentials (AWS, GCP, Azure, etc.)
# CLOUD_STORAGE_KEY=your_cloud_storage_key_here
# CLOUD_STORAGE_SECRET=your_cloud_storage_secret_here

# Third-party Integration Tokens (Slack, Discord, etc.)
# SLACK_BOT_TOKEN=your_slack_bot_token_here
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ============================================================================
# END OF CONFIGURATION TEMPLATE
# ============================================================================
